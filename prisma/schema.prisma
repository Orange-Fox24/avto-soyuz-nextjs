// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// СУЩЕСТВУЮЩИЕ ТАБЛИЦЫ
// ==========================================

model contact_applications {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(255)
  company    String?   @db.VarChar(255)
  phone      String    @db.VarChar(50)
  email      String?   @db.VarChar(255)
  topic      String    @db.VarChar(255)
  message    String
  status     String?   @default("new") @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  @@index([created_at], map: "idx_contact_created")
  @@index([status], map: "idx_contact_status")
  @@map("contact_applications")
}

model main_applications {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(255)
  company    String?   @db.VarChar(255)
  from_city  String    @db.VarChar(255)
  to_city    String?   @db.VarChar(255)
  phone      String?   @db.VarChar(50)
  email      String?   @db.VarChar(255)
  message    String
  status     String?   @default("new") @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  @@index([created_at], map: "idx_main_created")
  @@index([status], map: "idx_main_status")
  @@map("main_applications")
}

model partner_applications {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(255)
  company    String?   @db.VarChar(255)
  phone      String    @db.VarChar(50)
  email      String?   @db.VarChar(255)
  experience String
  message    String
  status     String?   @default("new") @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  @@index([created_at], map: "idx_partner_created")
  @@index([status], map: "idx_partner_status")
  @@map("partner_applications")
}

// ==========================================
// АУТЕНТИФИКАЦИЯ
// ==========================================

enum Role {
  CLIENT
  MANAGER
  DRIVER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  phone         String?
  password      String?
  role          Role      @default(CLIENT)
  isOnLeave     Boolean   @default(false)
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  orders        Order[]   @relation("ClientOrders")
  driverOrders  Order[]   @relation("DriverOrders")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Account {
  userId          String
  type            String
  provider        String
  providerAccountId String
  refresh_token   String?  @db.Text
  access_token    String?  @db.Text
  expires_at      Int?
  token_type      String?
  scope           String?
  id_token        String?  @db.Text
  session_state   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ==========================================
// ЗАКАЗЫ
// ==========================================

enum OrderStatus {
  NEW
  ASSIGNED
  LOADING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

model Order {
  id          String      @id @default(cuid())
  clientId    String
  driverId    String?
  vehicleId   String?
  fromCity    String
  toCity      String
  weight      Float
  cargoType   String      @default("Прочее")
  desiredDate DateTime?
  comment     String?
  status      OrderStatus @default(NEW)
  price       Float?
  isPaid      Boolean     @default(false)
  paidAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  client User  @relation("ClientOrders", fields: [clientId], references: [id])
  driver User? @relation("DriverOrders", fields: [driverId], references: [id])

  @@map("orders")
}

// ==========================================
// ТРАНСПОРТ
// ==========================================

model Vehicle {
  id            String   @id @default(cuid())
  brand         String
  model         String
  plateNumber   String   @unique
  type          String   @default("Тент")
  capacity      Float    @default(5)
  isAvailable   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("vehicles")
}